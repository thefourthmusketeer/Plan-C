# ─── Cloudflare ───────────────────────────────────────────────────────────────
# API token — needs Zone:DNS:Edit permission for your zone
CF_TOKEN=

# Zone ID — find it in Cloudflare dashboard → your domain → right sidebar
CF_ZONE_ID=

# ─── Domain ───────────────────────────────────────────────────────────────────
# Root domain (must be the zone managed by Cloudflare above)
ROOT_DOMAIN=yourdomain.com

# Subdomain prefix for the CDN alias (results in cdn.yourdomain.com)
# This is what clients put in SNI — must not be proxied in Cloudflare
CDN_SUBDOMAIN=cdn

# ─── xray / 3x-ui inbound ────────────────────────────────────────────────────
# Port xray listens on (CloudFront → VPS)
INBOUND_PORT=443

# WebSocket path — use something plausible-looking
WS_PATH=/api/v1/chat

# Remark/label for the inbound in 3x-ui
X_UI_REMARK=vless-ws-tls-cf

# VLESS UUID — leave blank to auto-generate
VLESS_UUID=
